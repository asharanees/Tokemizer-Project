# Tokemizer unified env template
#
# One file. Copy to `.env` in repo root.
# Docker Compose automatically loads `.env` (no `--env-file` needed).
#
# Deployment target (used for docs/ops only; Compose also maps this to APP_ENV)
TOKEMIZER_DEPLOY_TARGET=production

# Host ports
# - Windows local test: FRONTEND_PORT=8080 BACKEND_PORT=8000
# - Production w/ host Nginx reverse proxy: FRONTEND_PORT=8081 BACKEND_PORT=8001
FRONTEND_PORT=8080
BACKEND_PORT=8000

# Backend runtime tuning
UVICORN_WORKERS=1
OPTIMIZER_CACHE_SIZE=256
DB_PATH=/app/data/app.db

# Docker restart policy
TOKEMIZER_RESTART_POLICY=no

# Resource limits (Docker Compose deploy/resources may be ignored by Docker Desktop)
BACKEND_MEMORY_LIMIT=4G
BACKEND_CPU_LIMIT=1.5
BACKEND_MEMORY_RESERVATION=2G
BACKEND_CPU_RESERVATION=0.5

# Reverse-proxy timeout (frontend nginx)
BACKEND_PROXY_TIMEOUT=180s
# Max request body size accepted by frontend nginx (model archive uploads)
MODEL_UPLOAD_MAX_BODY=512m

# Persistent host folders (bind mounts)
# - Windows: C:/tokemizer/data  and  C:/tokemizer/model-cache
# - Linux:   /opt/tokemizer/data and /opt/tokemizer/model-cache
TOKEMIZER_BACKEND_DATA_PATH=C:/tokemizer/data
TOKEMIZER_MODEL_CACHE_PATH=C:/tokemizer/model-cache

# Optional server config
CORS_ORIGINS=*

# Optional Redis (rate limiting / caching)
# REDIS_URL=redis://localhost:6379/0

# Optional Hugging Face auth (required for private/gated model repos)
# HF_TOKEN=replace_me_with_hf_token
# HUGGINGFACE_HUB_TOKEN=replace_me_with_hf_token

# Required for auth in real deployments
# SECRET_KEY=change_me

# Optional billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional EC2 lifecycle control via Lambda (login-page start/stop/status)
# Set to true to enable public auth-route controls on /login page.
EC2_CONTROL_ENABLED=false
# Lambda function name or ARN used by backend to control EC2 state.
# EC2_CONTROL_LAMBDA_NAME=tokemizer-ec2-control
# Region override for Lambda invocation (defaults to AWS_REGION/us-east-1).
# EC2_CONTROL_AWS_REGION=us-east-1
# Optional Lambda alias/version.
# EC2_CONTROL_LAMBDA_QUALIFIER=live
