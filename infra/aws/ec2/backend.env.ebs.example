# Backend runtime (stored on EBS)
APP_ENV=production
PORT=8000
UVICORN_HOST=0.0.0.0
UVICORN_WORKERS=1
UVICORN_ACCESS_LOG=true

# Persist all account/auth/history/usage telemetry in SQLite on EBS
DB_PATH=/data/tokemizer/db/app.db

# Persist model cache on EBS
HF_HOME=/data/tokemizer/models/hf
TRANSFORMERS_CACHE=/data/tokemizer/models/hf

# Keep tiktoken artifacts local to app path
TIKTOKEN_CACHE_DIR=/opt/tokemizer/app/backend/vendor/tiktoken

# REQUIRED: replace with strong random value
SECRET_KEY=replace_me_with_random_64_chars

# CORS should be Amplify domain(s)
# Example:
# CORS_ORIGINS=https://main.xxxxx.amplifyapp.com,https://app.example.com
CORS_ORIGINS=https://example.com

# Optional tuning
OPTIMIZER_CACHE_SIZE=256
DB_POOL_SIZE=10
